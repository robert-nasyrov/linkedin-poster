# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_STRING_SESSION=your_string_session
TELEGRAM_ADMIN_ID=your_telegram_user_id
# Channel/chat to read digests from (username without @ or channel ID)
DIGEST_CHANNEL=zbsnewz

# === LinkedIn ===
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://your-app.up.railway.app/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# === Anthropic ===
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Database ===
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Schedule ===
# Cron-like: days of week (0=Mon, 6=Sun) and hour (Tashkent UTC+5)
POST_DAYS=0,2,4
POST_HOUR=10
